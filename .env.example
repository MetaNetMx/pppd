# ─────────────────────────────────────────────────────────────────────────────
# CLIENTE (variables VITE_*, se embeben en el build del navegador)
# Configúralas también desde Ajustes (⚙︎) en la app, sin tocar archivos.
# NO subas tu .env real a ningún repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# Conexión al chat (módulo Explorador y meditaciones a la medida).
# Si despliegas en Vercel con las funciones de /api, apunta al proxy propio:
VITE_API_PROXY_URL=/api/chat
# Alternativa para uso personal local (clave embebida y expuesta en el bundle):
# VITE_ANTHROPIC_API_KEY=sk-ant-...

# TTS neuronal de las meditaciones. Con las funciones de /api en Vercel:
VITE_TTS_ENDPOINT=/api/tts
# Voz por defecto (depende del proveedor; ej. Azure es-MX):
VITE_TTS_VOICE=es-MX-DaliaNeural

# ─────────────────────────────────────────────────────────────────────────────
# SERVIDOR (solo en Vercel / tu host — NUNCA con prefijo VITE_, no se exponen)
# Configúralas en el panel de Vercel: Project Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# Chat:
ANTHROPIC_API_KEY=sk-ant-...

# TTS: elige proveedor (azure | elevenlabs | openai). Por defecto: azure (es-MX real).
TTS_PROVIDER=azure
# Azure Speech (recomendado para es-MX):
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus
# ElevenLabs (alternativa):
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# OpenAI (alternativa):
# OPENAI_API_KEY=
